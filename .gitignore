# OS / editor
.DS_Store
*.log
*.swp
*.swo
.history/

# Node
node_modules/
npm-debug.log*

# Vite / Svelte build output
dist/
dist-linux/

# Tauri / Rust build output
src-tauri/target/
# Cargo.lock is gitignored for libraries, but MD Reader is a
# binary app — committing the lockfile makes every release
# reproducible (Tauri docs recommend this for app crates).
src-tauri/gen/

# Environment / secrets
.env
.env.local
.env.*.local

# IDE / agent session state (regenerated locally, never source)
.opencode/
.claude/
.mavis/
vault/
.vscode/
.idea/

# Local AI tooling state (regenerated on each run, not part of the public repo)
/.harness/
.harness/memory/

# OS junk
Thumbs.db

# stray top-level build/test output
target/
